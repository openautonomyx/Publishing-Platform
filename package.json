{
  "name": "openautonomyx",
  "version": "1.0.0",
  "description": "The global creative platform - Create once, publish everywhere, in any language",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run test",
    "publish:npm": "npm publish --access public",
    "docs": "typedoc src",
    "version": "npm run format && git add -A"
  },
  "keywords": [
    "openautonomyx",
    "creative",
    "publishing",
    "multilingual",
    "ai",
    "automation",
    "social-media",
    "content",
    "global",
    "platform"
  ],
  "author": {
    "name": "OpenAutonomyX Contributors",
    "email": "support@openautonomyx.com",
    "url": "https://openautonomyx.com"
  },
  "contributors": [
    {
      "name": "Claude AI (Haiku 4.5)",
      "email": "ai@anthropic.com",
      "url": "https://www.anthropic.com"
    },
    {
      "name": "Fractional PM",
      "email": "thefractionalpm@gmail.com"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openautonomyx/openautonomyx.git"
  },
  "bugs": {
    "url": "https://github.com/openautonomyx/openautonomyx/issues"
  },
  "homepage": "https://openautonomyx.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/?(*.)+(spec|test).ts"],
    "passWithNoTests": true
  }
}
