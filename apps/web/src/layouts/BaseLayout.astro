---
import "../../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <main class="mx-auto max-w-4xl px-6 py-16">
      <slot />
    </main>
  </body>
</html>
