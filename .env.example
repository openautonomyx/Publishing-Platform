# SurrealDB
SURREALDB_URL=http://127.0.0.1:8000/rpc
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_NAMESPACE=publishing
SURREALDB_DATABASE=platform

# Production Alternative Database URL
# DATABASE_URL=surrealdb://username:password@db:8000/namespace/database

# Auth.js / NextAuth
AUTH_SECRET=replace-with-a-secure-random-secret
AUTH_URL=http://localhost:4321

# App
NODE_ENV=development
APP_URL=http://localhost:4321
PUBLIC_APP_URL=http://localhost:4321

# Optional services
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
STRIPE_SECRET_KEY=
POSTHOG_KEY=

# SMTP (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
